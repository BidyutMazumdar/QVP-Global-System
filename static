<script>
// 🔒 HTML ESCAPE (XSS Protection)
function escapeHTML(str) {
    return String(str)
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;");
}

// 🔒 SAFE FETCH (timeout + validation + JSON safety)
async function safeFetch(url, timeout = 8000) {
    const controller = new AbortController();
    const id = setTimeout(() => controller.abort(), timeout);

    try {
        const res = await fetch(url, { signal: controller.signal });

        if (!res.ok) {
            throw new Error(`HTTP ${res.status}`);
        }

        const text = await res.text();
        if (!text) throw new Error("Empty response");

        return JSON.parse(text);

    } catch (err) {
        throw new Error(`Fetch failed: ${err.message}`);
    } finally {
        clearTimeout(id);
    }
}

// 🔒 MAIN LOADER (parallel + optimized + secure)
async function loadData() {
    try {
        // 🚀 Parallel fetch
        const [data, meta] = await Promise.all([
            safeFetch("/qssi/rankings"),
            safeFetch("/meta")
        ]);

        if (!data?.data || data.data.length === 0) {
            throw new Error("No dataset");
        }

        // 📊 META
        document.getElementById("meta").innerHTML = `
            <b>Version:</b> ${escapeHTML(meta?.version || "N/A")}<br>
            <b>Dataset Hash:</b> ${escapeHTML(meta?.dataset_hash || "N/A")}<br>
            <b>Run ID:</b> ${escapeHTML(meta?.run_id || "N/A")}
        `;

        // 🥇 LEADER
        const leader = data.data[0];
        document.getElementById("leader").innerHTML =
            `<b>${escapeHTML(leader?.Country || "Unknown")}</b> 
             (Score: ${escapeHTML(leader?.Score ?? "N/A")})`;

        // 🔝 TOP 10 (safe via innerText)
        const top10 = document.getElementById("top10");
        top10.innerHTML = "";

        data.data.slice(0, 10).forEach(c => {
            const li = document.createElement("li");
            li.innerText = `${c?.Rank ?? "-"} . ${c?.Country ?? "Unknown"} (${c?.Score ?? "N/A"})`;
            top10.appendChild(li);
        });

        // 📋 TABLE (single render + escaped)
        const table = document.getElementById("table");

        const rows = data.data.map(c => {
            const tierClass = (c?.Tier || "")
                .replace(/\s+/g, "")
                .toLowerCase();

            return `
                <tr>
                    <td>${escapeHTML(c?.Rank ?? "-")}</td>
                    <td>${escapeHTML(c?.Country ?? "Unknown")}</td>
                    <td>${escapeHTML(c?.QSSI ?? "-")}</td>
                    <td>${escapeHTML(c?.QSSI_adj ?? "-")}</td>
                    <td>${escapeHTML(c?.Score ?? "-")}</td>
                    <td class="${tierClass}">${escapeHTML(c?.Tier ?? "-")}</td>
                </tr>
            `;
        }).join("");

        table.innerHTML = rows;

    } catch (err) {
        console.error(err);

        document.getElementById("leader").innerHTML =
            `<div class='error'>System Error</div>`;

        document.getElementById("meta").innerHTML =
            `<div class='error'>Connection / API Failure</div>`;

        document.getElementById("top10").innerHTML = "";
        document.getElementById("table").innerHTML = "";
    }
}

// 🔒 INIT
loadData();
</script>
